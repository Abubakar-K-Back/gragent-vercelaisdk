    "@ai-sdk/openai": "^3.0.71",
    "@anthropic-ai/sdk": "^0.104.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oclif/core": "^4.11.5",
    "ai": "^6.0.206",
    "chalk": "^5.6.2",
    "express": "^5.2.1",
    "kafkajs": "^2.2.4",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3"
